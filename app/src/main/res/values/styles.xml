<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="text_settings">
        <item name="android:layout_height">61dp</item>
        <item name="android:layout_width">match_parent</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:textSize">@dimen/sp_16</item>
        <item name="android:textColor">@color/string</item>
        <item name="android:fontFamily">@font/ys_display_regular</item>
        <item name="android:textFontWeight">400</item>
    </style>

    <style name="BottomNavigationTextAppearance" parent="TextAppearance.MaterialComponents.Caption">
        <item name="fontFamily">@font/ys_display_medium</item>
        <item name="android:fontFamily">@font/ys_display_medium</item>
        <item name="android:textSize">12sp</item>
    </style>

    <style name="BottomNavigationStyle" parent="Widget.MaterialComponents.BottomNavigationView">
        <!-- Отключаем все анимации и увеличения -->
        <item name="labelVisibilityMode">labeled</item>
        <item name="itemHorizontalTranslationEnabled">false</item>

        <!-- Одинаковый стиль для активных и неактивных элементов -->
        <item name="itemTextAppearance">@style/BottomNavigationTextAppearance</item>
        <item name="itemTextAppearanceActive">@style/BottomNavigationTextAppearance</item>
        <item name="itemTextAppearanceInactive">@style/BottomNavigationTextAppearance</item>

        <!-- Фиксированный размер иконок -->
        <item name="itemIconSize">24dp</item>
    </style>

    <style name="toolbar">
        <item name="android:layout_height">@dimen/dp_56</item>
        <item name="android:layout_width">match_parent</item>
        <item name="titleTextAppearance">@style/toolbarAppearance</item>
        <item name="navigationIconTint">@color/string</item>
    </style>

    <style name="toolbarAppearance">
        <item name="android:titleTextColor">@color/string</item>
        <item name="android:fontFamily">@font/ys_display_medium</item>
        <item name="android:textFontWeight">500</item>
        <item name="android:textSize">@dimen/sp_22</item>
    </style>

    <style name="btn_main">
        <item name="android:layout_height">0dp</item>
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_marginHorizontal">@dimen/dp_20</item>
        <item name="android:layout_marginBottom">4dp</item>
        <item name="android:layout_weight">1</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">@dimen/sp_22</item>
        <item name="android:textColor">@color/color_icon_main</item>
        <item name="android:backgroundTint">@color/white</item>
        <item name="android:fontFamily">@font/ys_display_medium</item>
        <item name="android:textFontWeight">500</item>
        <item name="iconTint">@color/color_icon_main</item>
        <item name="iconGravity">textStart</item>
        <!-- удаление тени -->
        <item name="android:stateListAnimator">@null</item>
    </style>

    <style name="NoCapsTabLayout" parent="Theme.AppCompat.Light">
        <!-- ФОН ВСЕГО TABLAYOUT -->
        <item name="android:background">@color/bg_activity</item>

        <!-- СТИЛЬ ТЕКСТА ВКЛАДОК -->
        <item name="tabTextAppearance">@style/TabTextAppearance</item>

        <!-- ЦВЕТ ИНДИКАТОРА (полоска снизу активной вкладки) -->
        <item name="tabIndicatorColor">@color/string</item>

        <!-- ВЫСОТА ИНДИКАТОРА -->
        <item name="tabIndicatorHeight">2dp</item>

        <!-- ЦВЕТ ТЕКСТА ВКЛАДКИ -->
        <item name="tabTextColor">@color/string</item>

        <!-- РЕЖИМ ОТОБРАЖЕНИЯ ВКЛАДОК -->
        <item name="tabMode">fixed</item>

        <!-- ВЫРАВНИВАНИЕ ВКЛАДОК -->
        <item name="tabGravity">fill</item>

        <!-- ШИРИНА ИНДИКАТОРА: false = под текстом, true = на всю ширину вкладки -->
        <item name="tabIndicatorFullWidth">false</item>
    </style>

    <!-- СТИЛЬ ТЕКСТА ДЛЯ ВКЛАДОК -->
    <style name="TabTextAppearance" parent="TextAppearance.AppCompat.Button">
        <!-- ОТКЛЮЧАЕМ ВСЕ ЗАГЛАВНЫЕ БУКВЫ -->
        <item name="textAllCaps">false</item>
        <item name="android:textAllCaps">false</item>

        <!-- РАЗМЕР ШРИФТА -->
        <item name="android:textSize">14sp</item>

        <!-- ШРИФТ -->
        <item name="android:fontFamily">@font/ys_display_medium</item>
        <item name="android:textFontWeight">500</item>

        <!-- МЕЖСТРОЧНЫЙ ИНТЕРВАЛ -->
        <item name="android:lineSpacingExtra">4sp</item>
    </style>


    <style name="CustomMaterialDialog" parent="ThemeOverlay.MaterialComponents.MaterialAlertDialog">
        <!-- Фон диалога -->
        <item name="android:background">#ffffff</item>

        <!-- Цвет текста заголовка и сообщения -->
        <item name="colorOnSurface">#000000</item>

        <!-- Стиль Positive кнопки (ОК/Да) -->
        <item name="buttonBarPositiveButtonStyle">@style/PositiveButtonStyle</item>

        <!-- Стиль Negative кнопки (Отмена/Нет) -->
        <item name="buttonBarNegativeButtonStyle">@style/NegativeButtonStyle</item>
    </style>

    <!-- Стиль для Positive кнопки -->
    <style name="PositiveButtonStyle" parent="Widget.MaterialComponents.Button.TextButton">
        <item name="android:textColor">#3772E7</item>
    </style>

    <!-- Стиль для Negative кнопки -->
    <style name="NegativeButtonStyle" parent="Widget.MaterialComponents.Button.TextButton">
        <item name="android:textColor">#3772E7</item>
    </style>

</resources>