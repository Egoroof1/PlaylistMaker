<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="4dp"
    android:layout_marginBottom="@dimen/dp_16">

    <ImageView
        android:id="@+id/iv_cover_item_playlist"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@drawable/bg_corners_8"
        android:clipToOutline="true"
        android:contentDescription="@string/track_cover"
        android:scaleType="centerCrop"
        android:src="@drawable/placeholder"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:targetApi="31" />

    <TextView
        android:id="@+id/tv_item_playlist_name"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:ellipsize="end"
        android:maxLines="1"
        android:textSize="16sp"
        app:layout_constraintEnd_toEndOf="@id/iv_cover_item_playlist"
        app:layout_constraintStart_toStartOf="@id/iv_cover_item_playlist"
        app:layout_constraintTop_toBottomOf="@id/iv_cover_item_playlist"
        style="@style/text_settings"
        tools:text="Name" />

    <TextView
        android:id="@+id/tv_item_playlist_quantity_tracks"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:ellipsize="end"
        android:maxLines="1"
        android:textSize="16sp"
        app:layout_constraintEnd_toEndOf="@id/iv_cover_item_playlist"
        app:layout_constraintStart_toStartOf="@id/iv_cover_item_playlist"
        app:layout_constraintTop_toBottomOf="@id/tv_item_playlist_name"
        style="@style/text_settings"
        tools:text="157 треков" />

</androidx.constraintlayout.widget.ConstraintLayout>