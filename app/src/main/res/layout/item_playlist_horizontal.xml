<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="61dp"
    xmlns:tools="http://schemas.android.com/tools">

    <ImageView
        android:id="@+id/image"
        android:layout_width="45dp"
        android:layout_height="45dp"
        android:layout_marginStart="13dp"
        android:contentDescription="@string/arrow_forward"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/et_name_playlist"
        style="@style/text_settings"
        android:layout_width="0dp"
        android:layout_height="19dp"
        android:layout_marginStart="8dp"
        android:layout_marginTop="14dp"
        android:layout_marginEnd="44dp"
        android:ellipsize="end"
        android:maxLines="1"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/image"
        app:layout_constraintTop_toTopOf="parent"
        tools:text="Playlist name" />

    <TextView
        style="@style/text_settings"
        android:id="@+id/tv_item_playlist_quantity_tracks"
        android:layout_width="wrap_content"
        android:layout_height="13dp"
        android:maxWidth="100dp"
        android:ellipsize="end"
        android:maxLines="1"
        android:textSize="11sp"
        android:textColor="@color/color_icon_setting"
        app:layout_constraintStart_toStartOf="@+id/et_name_playlist"
        app:layout_constraintTop_toBottomOf="@+id/et_name_playlist"
        tools:text="98 tracks" />

</androidx.constraintlayout.widget.ConstraintLayout>